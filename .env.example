# ─── Algorand ────────────────────────────────────────────
ALGORAND_NETWORK=testnet
ALGORAND_ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud

# Provider wallet (generate with Algorand SDK or use MyAlgo/Pera wallet)
PROVIDER_WALLET_ADDRESS=your_algorand_testnet_address_here
PROVIDER_WALLET_MNEMONIC=your 25 word mnemonic phrase here

# ─── FastAPI AI Services ────────────────────────────────
AI_SERVICE_PORT=8001
AI_SERVICE_HOST=0.0.0.0
INTERNAL_API_SECRET=super-secret-internal-key-change-me

# ─── Node.js Gateway ────────────────────────────────────
GATEWAY_PORT=8000
AI_SERVICES_URL=http://localhost:8001
SIMULATION_MODE=true

# ─── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
NEXT_PUBLIC_AI_SERVICES_URL=http://localhost:8001
