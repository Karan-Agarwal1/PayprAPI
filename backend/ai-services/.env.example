# PayprAPI AI Services - Backend Configuration
# ---------------------------------------------
# Use these variables in your Render environment setup

# Server Configuration
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001

# Algorand Blockchain Configuration
# Set to 'false' in production to actually verify real ALGO transactions. 
# Set to 'true' for a simulated trial (no blockchain needed).
SIMULATION_MODE=false

# Algorand Network Settings (Testnet)
ALGORAND_NETWORK=testnet
ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_ALGOD_TOKEN=

# The escrow wallet address where users send ALGO
PROVIDER_WALLET_ADDRESS=PAYPRAPI7ESCROWV2XKAGALGO4482TESTNET99017777777777777777777
