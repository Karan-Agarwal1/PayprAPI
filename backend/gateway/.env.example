# PayprAPI Gateway - Configuration
# ---------------------------------------------
# Use these variables in your Render environment setup for the Gateway

# Server Port
GATEWAY_PORT=8000

# URL of the AI Services backend (deployed on Render)
# Example: https://payprapi-ai-services.onrender.com
AI_SERVICES_URL=http://localhost:8001

# Algorand Blockchain Configuration
# Set to 'false' in production to actually verify real ALGO transactions. 
SIMULATION_MODE=false

ALGORAND_NETWORK=testnet
ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_ALGOD_TOKEN=

# Escrow details (must match ai-services config)
PROVIDER_WALLET_ADDRESS=3GET3TZOGXE2O3KQWKCMRSLJTRZUWTIKMTSN55XOPWNI3U3IGCU6RXLBRE
PROVIDER_ID=prov_Kag7
